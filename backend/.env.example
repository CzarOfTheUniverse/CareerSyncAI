# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and must never be committed.

# ── Backend server ────────────────────────────────────────────────
# Host the backend binds to. Default 127.0.0.1 keeps it reachable only
# from the local reverse proxy. Change only if you know what you're doing.
API_BACKEND_HOST="127.0.0.1"

# Port the backend listens on.
API_BACKEND_PORT=5000

# Max request body size accepted by the proxy.
API_PAYLOAD_MAX_SIZE="7mb"

# ── Google Cloud / Vertex AI ──────────────────────────────────────
# Your Google Cloud project ID and the Vertex AI location/region.
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="global"

# Path to a service-account JSON key with Vertex AI access. Consumed by
# Application Default Credentials (google-auth-library). For local dev you
# may instead run `gcloud auth application-default login` and leave this unset.
# GOOGLE_APPLICATION_CREDENTIALS="/secrets/service-account.json"

# ── App OAuth + model (served to the browser via GET /config) ─────
# The single Google OAuth Client ID end users sign in with. Set this so users
# never have to paste their own. Leave blank to keep the per-user input box.
GOOGLE_OAUTH_CLIENT_ID=""

# Gemini model the frontend should use. Defaults to gemini-2.5-flash.
GEMINI_MODEL="gemini-2.5-flash"

# Default Gmail look-back window (days) for new sessions.
LOOKBACK_DAYS_DEFAULT=90

# ── Access control (the real boundary for a shared URL) ───────────
# When either of these is set, the backend verifies each user's Google token
# and only allows listed accounts to use the Vertex proxy. Leave both blank to
# disable user-level enforcement (dev / single-user).
# Comma-separated list of allowed emails:
ALLOWED_EMAILS=""
# Or allow a whole Google Workspace domain (the token's hd claim):
ALLOWED_HOSTED_DOMAIN=""

# ── Proxy guard ───────────────────────────────────────────────────
# Shared header the frontend shim stamps on proxied requests. Generate a
# fresh random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
# NOTE: this value ships inside client JS, so it is a basic guard, not a
# real auth boundary. The real access control (Google ID-token verification
# + allow-list) is added in the auth-overhaul phase.
PROXY_HEADER="generate-a-random-value"
